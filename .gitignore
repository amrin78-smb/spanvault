node_modules/
.next/
*.tsbuildinfo

# Update-SpanVault.ps1 rollback snapshots (node_modules.lastgood,
# .next.lastgood, etc.) — the updater's own `git clean --exclude="*.lastgood"`
# already protects a real deployed install, but ignore here too as
# defense-in-depth so a stray leftover from a local/dev run can't accidentally
# get swept into a normal `git add -A` commit.
*.lastgood/
.env.local
!.env.local.example
*.log
# Agent runtime files (generated at install time / runtime on the remote server)
agent/config.json
agent/buffer.json

# packaging archives (build/distribution output, never source)
*.zip

# Claude Code web UI attachments (local scratch, never source)
.claude-web-files/
.claude-web-images/

# local dev seed script (not source)
frontend/demo-seed.js

.commit-msg.tmp
