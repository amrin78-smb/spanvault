# Replace SERVER_IP with the actual server IP/hostname at install time.
SV_APP_PORT=3008
SV_API_PORT=3009
# WebSocket server for distributed polling agents (must be reachable from agents).
SV_WS_PORT=3010
# Optional: terminate TLS (wss://) on the agent WebSocket. Set both to PEM file
# paths to enable; leave blank for plain ws:// on a trusted LAN / behind a proxy.
SV_WS_TLS_CERT=
SV_WS_TLS_KEY=
# Optional: path to nssm.exe the server hands to the agent installer (so remote
# hosts never need the public nssm.cc). Defaults to NetVault's bundled copy.
SV_NSSM_PATH=
# Public base URL agents use to download files + connect (frontend proxies /api/*).
SV_PUBLIC_URL=http://SERVER_IP:3008
NEXTAUTH_URL=http://SERVER_IP:3008
NEXTAUTH_SECRET=bue3VdWszntJ24GMhfKg1QkPIEaZYC95
NOCVAULT_HUB_URL=http://SERVER_IP:3000
NEXT_PUBLIC_NOCVAULT_HUB_URL=http://SERVER_IP:3000
NETVAULT_DB_HOST=localhost
NETVAULT_DB_PORT=5432
NETVAULT_DB_NAME=netvault
NETVAULT_DB_USER=netvault
NETVAULT_DB_PASS=PgAdmin@2026!
SV_DB_HOST=localhost
SV_DB_PORT=5432
SV_DB_NAME=spanvault
SV_DB_USER=spanvault_user
SV_DB_PASS=NVAdmin@2026
# postgres superuser password — used by the installer to grant spanvault_user
# read access to the netvault DB (CONNECT/USAGE/SELECT) on first install.
POSTGRES_PASSWORD=your_postgres_superuser_password
# Server IP/hostname for the in-app updater (Settings -> Updates) to re-run the
# installer. The installer sets this on fresh install.
SERVER_IP=your_server_ip
